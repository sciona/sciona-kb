---
/**
 * Static SVG thumbnail of a CDG pipeline topology.
 * Shows stages as small nodes and edges as lines, auto-laid out
 * left-to-right using a simple topological sort + rank assignment.
 */

interface Stage {
  stage_id: string;
  name: string;
  concept_type: string;
}

interface Edge {
  source_stage_id: string;
  target_stage_id: string;
  loss_class?: string;
}

interface Binding {
  stage_id: string;
  status: string;
}

interface Props {
  stages: Stage[];
  edges: Edge[];
  bindings?: Binding[];
  width?: number;
  height?: number;
}

const { stages, edges, bindings = [], width = 240, height = 140 } = Astro.props;

// Build adjacency and compute ranks via topological layering
const adj = new Map<string, string[]>();
const inDegree = new Map<string, number>();
const stageIds = new Set(stages.map((s) => s.stage_id));

for (const id of stageIds) {
  adj.set(id, []);
  inDegree.set(id, 0);
}
for (const e of edges) {
  if (stageIds.has(e.source_stage_id) && stageIds.has(e.target_stage_id)) {
    adj.get(e.source_stage_id)!.push(e.target_stage_id);
    inDegree.set(e.target_stage_id, (inDegree.get(e.target_stage_id) ?? 0) + 1);
  }
}

// Assign ranks (columns) via BFS layering
const rank = new Map<string, number>();
const queue: string[] = [];
for (const [id, deg] of inDegree) {
  if (deg === 0) { queue.push(id); rank.set(id, 0); }
}

let maxRank = 0;
while (queue.length > 0) {
  const id = queue.shift()!;
  const r = rank.get(id)!;
  for (const next of adj.get(id) ?? []) {
    const nextRank = Math.max(rank.get(next) ?? 0, r + 1);
    rank.set(next, nextRank);
    maxRank = Math.max(maxRank, nextRank);
    inDegree.set(next, (inDegree.get(next) ?? 1) - 1);
    if (inDegree.get(next) === 0) queue.push(next);
  }
}

// Handle unranked nodes (cycles or disconnected)
for (const id of stageIds) {
  if (!rank.has(id)) { rank.set(id, maxRank + 1); maxRank = rank.get(id)!; }
}

// Group by rank for y-positioning
const byRank = new Map<number, string[]>();
for (const [id, r] of rank) {
  const list = byRank.get(r) ?? [];
  list.push(id);
  byRank.set(r, list);
}

// Compute positions
const PAD_X = 16;
const PAD_Y = 14;
const usableW = width - PAD_X * 2;
const usableH = height - PAD_Y * 2;
const cols = maxRank + 1;
const colW = cols > 1 ? usableW / (cols - 1) : usableW / 2;

const NODE_R = 5;
const pos = new Map<string, { x: number; y: number }>();

for (const [r, ids] of byRank) {
  const x = cols > 1 ? PAD_X + r * colW : width / 2;
  const rowH = ids.length > 1 ? usableH / (ids.length - 1) : 0;
  ids.forEach((id, i) => {
    const y = ids.length > 1 ? PAD_Y + i * rowH : height / 2;
    pos.set(id, { x, y });
  });
}

// Binding status for coloring
const bindingStatus = new Map(bindings.map((b) => [b.stage_id, b.status]));

function nodeColor(id: string): string {
  const status = bindingStatus.get(id);
  if (status === "active") return "#4ade80";
  if (status === "approximate") return "#facc15";
  if (status === "gap") return "#f87171";
  return "#6c8cff";
}

function edgeColor(e: Edge): string {
  if (e.loss_class === "irreversible") return "#f87171";
  if (e.loss_class === "lossy_but_allowed") return "#facc15";
  return "#4a5068";
}
---

<svg
  viewBox={`0 0 ${width} ${height}`}
  class="w-full h-full"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <rect width={width} height={height} rx="8" fill="#14161e" />

  <!-- Edges -->
  {edges.map((e) => {
    const from = pos.get(e.source_stage_id);
    const to = pos.get(e.target_stage_id);
    if (!from || !to) return null;
    return (
      <line
        x1={from.x}
        y1={from.y}
        x2={to.x}
        y2={to.y}
        stroke={edgeColor(e)}
        stroke-width="2"
        opacity="0.8"
      />
    );
  })}

  <!-- Nodes -->
  {stages.map((s) => {
    const p = pos.get(s.stage_id);
    if (!p) return null;
    const connected = edges.some(
      (e) => e.source_stage_id === s.stage_id || e.target_stage_id === s.stage_id
    );
    return (
      <circle
        cx={p.x}
        cy={p.y}
        r={connected ? NODE_R : NODE_R - 1.5}
        fill={nodeColor(s.stage_id)}
        opacity={connected ? 0.8 : 0.35}
      />
    );
  })}
</svg>
