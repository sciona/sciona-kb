---
interface Props {
  contentPath: string;
}

const { contentPath } = Astro.props;
const editUrl = `https://github.com/sciona/sciona-kb/edit/main/src/content/${contentPath}`;
---

<a
  href={editUrl}
  class="inline-flex items-center gap-1 text-sm text-atlas-text-muted hover:text-atlas-accent transition-colors float-right"
  target="_blank"
  rel="noopener"
>
  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
  </svg>
  Edit this page
</a>
