---
interface Props {
  cdgId?: string;
  atomFqdn?: string;
  label?: string;
  variant?: "primary" | "secondary";
}

const { cdgId, atomFqdn, label = "Open in Sciona", variant = "primary" } = Astro.props;

const baseUrl = "https://app.sciona.dev";
const href = cdgId
  ? `${baseUrl}/cdg/${cdgId}`
  : atomFqdn
    ? `${baseUrl}/atom/${atomFqdn}`
    : baseUrl;

const classes = variant === "primary"
  ? "bg-atlas-accent text-white hover:bg-atlas-accent-hover"
  : "border border-atlas-border text-atlas-text hover:border-atlas-accent hover:text-atlas-accent";
---

<a
  href={href}
  class:list={["inline-flex items-center justify-center px-6 py-3 rounded-lg font-medium transition-colors", classes]}
  target="_blank"
  rel="noopener"
>
  {label}
  <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
  </svg>
</a>
