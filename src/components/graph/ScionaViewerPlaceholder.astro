---
interface Props {
  cdgId: string;
  readOnly?: boolean;
  height?: string;
}

const { cdgId, readOnly = true, height = "400px" } = Astro.props;
---

<div
  class="bg-atlas-surface rounded-lg border border-atlas-border flex items-center justify-center"
  style={`height: ${height}`}
>
  <div class="text-center p-8">
    <svg class="w-12 h-12 mx-auto text-atlas-text-muted mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z" />
    </svg>
    <p class="text-atlas-text-muted text-sm mb-3">Interactive CDG Viewer</p>
    <a
      href={`https://app.sciona.dev/cdg/${cdgId}`}
      class="inline-flex items-center gap-1 text-sm text-atlas-accent hover:text-atlas-accent-hover transition-colors"
      target="_blank"
      rel="noopener"
    >
      Open in Sciona
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
      </svg>
    </a>
  </div>
</div>
