---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import Breadcrumbs from "../components/seo/Breadcrumbs.astro";
import TypeSignature from "../components/content/TypeSignature.astro";
import IOSpecTable from "../components/content/IOSpecTable.astro";
import AtomReverseLinks from "../components/content/AtomReverseLinks.astro";
import PlatformCTA from "../components/cta/PlatformCTA.astro";
import GitHubEditLink from "../components/cta/GitHubEditLink.astro";

interface Props {
  atom: CollectionEntry<"atoms">;
  contentPath: string;
  relatedAtoms?: CollectionEntry<"atoms">[];
}

const { atom, contentPath, relatedAtoms = [] } = Astro.props;
const { data } = atom;

const breadcrumbs = [
  { label: "Atlas", href: "/" },
  { label: "Atoms", href: "/atoms" },
  { label: data.concept_type.replace(/_/g, " "), href: `/concept/${data.concept_type}` },
  { label: data.title, href: Astro.url.pathname },
];
---

<BaseLayout title={data.title} description={data.description}>
  <div class="max-w-4xl mx-auto">
    <Breadcrumbs segments={breadcrumbs} />
    <GitHubEditLink contentPath={contentPath} />

    <h1 class="text-3xl font-bold mt-4 mb-2">{data.title}</h1>
    <p class="text-atlas-text-muted text-lg mb-6">{data.informal_desc}</p>

    <div class="flex flex-wrap gap-2 mb-6">
      <a href={`/concept/${data.concept_type}`} class="tag-link tag-accent">{data.concept_type.replace(/_/g, " ")}</a>
      <span class="tag-link">{data.repo}</span>
      <span class="tag-link">{data.verification_level.replace(/_/g, " ")}</span>
    </div>

    <div data-pagefind-ignore>
    <TypeSignature signature={data.type_signature} />

    {data.inputs.length > 0 && (
      <section class="mt-8">
        <h2 class="text-xl font-semibold mb-3">Inputs</h2>
        <IOSpecTable specs={data.inputs} direction="input" />
      </section>
    )}

    {data.outputs.length > 0 && (
      <section class="mt-8">
        <h2 class="text-xl font-semibold mb-3">Outputs</h2>
        <IOSpecTable specs={data.outputs} direction="output" />
      </section>
    )}

    <article class="prose prose-invert max-w-none mt-8">
      <slot />
    </article>
    </div><!-- end data-pagefind-ignore -->

    {data.references.length > 0 && (
      <section class="mt-8">
        <h2 class="text-xl font-semibold mb-3">References</h2>
        <ul class="space-y-2">
          {data.references.map((ref) => (
            <li class="text-atlas-text-muted">
              <span class="text-atlas-text font-medium">{ref.title}</span>
              {ref.url ? (
                <a href={ref.url} class="text-atlas-accent hover:text-atlas-accent-hover ml-2" target="_blank" rel="noopener">{ref.citation}</a>
              ) : (
                <span class="ml-2">{ref.citation}</span>
              )}
            </li>
          ))}
        </ul>
      </section>
    )}

    {data.used_by_cdgs.length > 0 && (
      <section class="mt-8">
        <h2 class="text-xl font-semibold mb-3">Used in CDGs</h2>
        <AtomReverseLinks cdgAssetIds={data.used_by_cdgs} />
      </section>
    )}

    {data.used_with && data.used_with.length > 0 && (
      <section class="mt-8">
        <h2 class="text-xl font-semibold mb-3">Often Used With</h2>
        <div class="space-y-2">
          {data.used_with.map((uw) => {
            const parts = uw.atom.replace("sciona.atoms.", "").split(".");
            const name = parts[parts.length - 1].replace(/_/g, " ");
            const href = `/atoms/${parts.map((p: string) => p.replace(/_/g, "-")).join("/")}`;
            const arrow = uw.direction === "upstream" ? "←" : "→";
            const label = uw.direction === "upstream" ? "feeds into this" : "receives from this";
            return (
              <a href={href} class="group flex items-center gap-3 px-3 py-2 rounded-lg bg-atlas-surface border border-atlas-border hover:border-atlas-accent/40 transition-colors">
                <span class="text-atlas-text-muted text-sm">{arrow}</span>
                <div class="flex-1 min-w-0">
                  <span class="font-mono text-xs text-atlas-accent group-hover:text-atlas-accent-hover transition-colors">{name}</span>
                  <span class="text-xs text-atlas-text-muted ml-2">{label}</span>
                </div>
                <span class="text-[10px] text-atlas-text-muted bg-atlas-surface-2 px-1.5 py-0.5 rounded">{uw.relationship.replace(/_/g, " ")}</span>
              </a>
            );
          })}
        </div>
      </section>
    )}

    {relatedAtoms.length > 0 && (
      <section class="mt-10">
        <hr class="section-rule mb-8" />
        <div class="flex items-baseline justify-between mb-4">
          <h2 class="text-xl font-semibold">Related Atoms</h2>
          <a href={`/concept/${data.concept_type}`} class="text-sm text-atlas-text-muted hover:text-atlas-accent transition-colors">
            All {data.concept_type.replace(/_/g, " ")} &rarr;
          </a>
        </div>
        <div class="grid gap-3 sm:grid-cols-2">
          {relatedAtoms.map((rel) => (
            <a href={`/atoms/${rel.id}`} class="group block p-3 rounded-lg bg-atlas-surface border border-atlas-border card-hover hover:border-atlas-accent/50">
              <h3 class="font-semibold text-sm group-hover:text-atlas-accent transition-colors mb-1 line-clamp-1">{rel.data.title}</h3>
              <p class="text-xs text-atlas-text-muted line-clamp-2">{rel.data.informal_desc}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <div class="mt-12">
      <PlatformCTA atomFqdn={data.fqdn} label="Use this atom in Sciona" />
    </div>
  </div>
</BaseLayout>
