---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import Breadcrumbs from "../components/seo/Breadcrumbs.astro";
import PlatformCTA from "../components/cta/PlatformCTA.astro";
import GitHubEditLink from "../components/cta/GitHubEditLink.astro";

interface Props {
  solution: CollectionEntry<"solutions">;
  contentPath: string;
}

const { solution, contentPath } = Astro.props;
const { data } = solution;

const breadcrumbs = [
  { label: "Atlas", href: "/" },
  { label: "Solutions", href: "/solutions" },
  { label: data.platform, href: `/solutions?platform=${data.platform}` },
  { label: data.title, href: Astro.url.pathname },
];

const cdgSlug = data.cdg_asset_id.replace("solution.kaggle.", "").replace(/\./g, "-");
---

<BaseLayout title={data.title} description={data.description}>
  <div class="max-w-4xl mx-auto">
    <Breadcrumbs segments={breadcrumbs} />
    <GitHubEditLink contentPath={contentPath} />

    <h1 class="text-3xl font-bold mt-4 mb-2">{data.title}</h1>

    <div class="flex flex-wrap gap-2 mb-6">
      <span class="px-2 py-1 text-xs rounded bg-atlas-accent/10 border border-atlas-accent/30 text-atlas-accent">{data.platform}</span>
      <span class="px-2 py-1 text-xs rounded bg-atlas-surface-2 border border-atlas-border text-atlas-text-muted">{data.placement}</span>
      <span class="px-2 py-1 text-xs rounded bg-atlas-surface-2 border border-atlas-border text-atlas-text-muted">{data.year}</span>
      <a href={`/paradigm/${data.paradigm}`} class="px-2 py-1 text-xs rounded bg-atlas-surface-2 border border-atlas-border text-atlas-text-muted hover:text-atlas-accent transition-colors">{data.paradigm}</a>
      <a href={`/family/${data.family}`} class="px-2 py-1 text-xs rounded bg-atlas-surface-2 border border-atlas-border text-atlas-text-muted hover:text-atlas-accent transition-colors">{data.family}</a>
    </div>

    {data.key_insight && (
      <div class="bg-atlas-accent/5 border border-atlas-accent/20 rounded-lg p-4 mb-6">
        <p class="text-sm font-medium text-atlas-accent mb-1">Key Insight</p>
        <p class="text-atlas-text">{data.key_insight}</p>
      </div>
    )}

    <article class="prose prose-invert max-w-none">
      <slot />
    </article>

    {data.failure_modes.length > 0 && (
      <section class="mt-8">
        <h2 class="text-xl font-semibold mb-3">Failure Modes</h2>
        <ul class="space-y-2">
          {data.failure_modes.map((fm) => (
            <li class="flex gap-2 text-atlas-text-muted">
              <span class="text-atlas-yellow shrink-0">!</span>
              <span>{fm}</span>
            </li>
          ))}
        </ul>
      </section>
    )}

    <div class="mt-12 flex flex-col sm:flex-row gap-4">
      <PlatformCTA cdgId={data.cdg_asset_id} label="Reproduce this solution in Sciona" />
      <a href={`/cdgs/${cdgSlug}`} class="inline-flex items-center justify-center px-6 py-3 rounded-lg border border-atlas-border text-atlas-text hover:border-atlas-accent hover:text-atlas-accent transition-colors font-medium">
        View CDG Breakdown
      </a>
    </div>

    {data.source_url && (
      <p class="mt-4 text-sm text-atlas-text-muted">
        Source: <a href={data.source_url} class="text-atlas-accent hover:text-atlas-accent-hover" target="_blank" rel="noopener">{data.source_url}</a>
        {data.source_license && ` (${data.source_license})`}
      </p>
    )}
  </div>
</BaseLayout>
