---
import "../styles/global.css";
import SEOHead from "../components/seo/SEOHead.astro";
import Navbar from "../components/nav/Navbar.astro";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalUrl?: string;
  jsonLd?: Record<string, unknown>;
}

const { title, description, ogImage, canonicalUrl, jsonLd } = Astro.props;
const siteName = "Sciona Algorithm Atlas";
const fullTitle = `${title} | ${siteName}`;
---

<!doctype html>
<html lang="en" class="bg-atlas-bg text-atlas-text">
  <head>
    <SEOHead
      title={fullTitle}
      description={description}
      canonicalUrl={canonicalUrl}
      ogImage={ogImage}
      jsonLd={jsonLd}
    />
  </head>
  <body class="min-h-screen flex flex-col font-sans antialiased">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:bg-atlas-accent focus:text-white focus:px-4 focus:py-2 focus:rounded">
      Skip to content
    </a>
    <Navbar />
    <main id="main" class="flex-1 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8" data-pagefind-body>
      <slot />
    </main>
    <footer class="border-t border-atlas-border mt-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <!-- Top: branding + nav columns -->
        <div class="grid gap-10 sm:grid-cols-12 mb-10">
          <!-- Branding -->
          <div class="sm:col-span-4">
            <a href="/" class="font-bold text-lg text-atlas-text mb-3 block">
              <span class="gradient-text">S</span>ciona Atlas
            </a>
            <p class="text-sm text-atlas-text-muted leading-relaxed">
              An open encyclopedia of algorithmic pipelines and composable building blocks. Learn how competition-winning algorithms work, from high-level mental models to contract-verified code.
            </p>
          </div>

          <!-- Nav columns -->
          <div class="sm:col-span-8 grid grid-cols-2 sm:grid-cols-3 gap-8 text-sm">
            <div>
              <h4 class="font-medium text-atlas-text mb-3">Explore</h4>
              <ul class="space-y-2 text-atlas-text-muted">
                <li><a href="/cdgs" class="hover:text-atlas-accent transition-colors">Pipelines</a></li>
                <li><a href="/atoms" class="hover:text-atlas-accent transition-colors">Atoms</a></li>
                <li><a href="/concepts" class="hover:text-atlas-accent transition-colors">Concepts</a></li>
                <li><a href="/solutions" class="hover:text-atlas-accent transition-colors">Solutions</a></li>
                <li><a href="/glossary" class="hover:text-atlas-accent transition-colors">Glossary</a></li>
              </ul>
            </div>
            <div>
              <h4 class="font-medium text-atlas-text mb-3">Popular</h4>
              <ul class="space-y-2 text-atlas-text-muted">
                <li><a href="/paradigm/neural_network" class="hover:text-atlas-accent transition-colors">Neural Networks</a></li>
                <li><a href="/paradigm/optimization" class="hover:text-atlas-accent transition-colors">Optimization</a></li>
                <li><a href="/concept/loss_function" class="hover:text-atlas-accent transition-colors">Loss Functions</a></li>
                <li><a href="/concept/data_assembly" class="hover:text-atlas-accent transition-colors">Data Assembly</a></li>
                <li><a href="/concept/signal_transform" class="hover:text-atlas-accent transition-colors">Signal Transforms</a></li>
              </ul>
            </div>
            <div>
              <h4 class="font-medium text-atlas-text mb-3">Sciona</h4>
              <ul class="space-y-2 text-atlas-text-muted">
                <li><a href="https://app.sciona.dev" class="hover:text-atlas-accent transition-colors" target="_blank" rel="noopener">Platform</a></li>
                <li><a href="https://github.com/sciona" class="hover:text-atlas-accent transition-colors" target="_blank" rel="noopener">GitHub</a></li>
                <li><a href="https://github.com/sciona/sciona-kb" class="hover:text-atlas-accent transition-colors" target="_blank" rel="noopener">Atlas Source</a></li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Bottom bar -->
        <hr class="section-rule mb-5" />
        <div class="flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-atlas-text-muted">
          <p>&copy; {new Date().getFullYear()} Sciona. All rights reserved.</p>
          <p>Built with <a href="https://astro.build" class="text-atlas-accent hover:text-atlas-accent-hover transition-colors" target="_blank" rel="noopener">Astro</a> &middot; Search by <a href="https://pagefind.app" class="text-atlas-accent hover:text-atlas-accent-hover transition-colors" target="_blank" rel="noopener">Pagefind</a></p>
        </div>
      </div>
    </footer>
  </body>
</html>
