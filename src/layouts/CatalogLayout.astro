---
import BaseLayout from "./BaseLayout.astro";
import Breadcrumbs from "../components/seo/Breadcrumbs.astro";

interface CatalogItem {
  slug: string;
  href: string;
  title: string;
  description: string;
  tags: string[];
}

interface Props {
  title: string;
  description: string;
  items: CatalogItem[];
  breadcrumbs?: Array<{ label: string; href: string }>;
}

const { title, description, items, breadcrumbs: crumbs } = Astro.props;
const defaultCrumbs = [
  { label: "Atlas", href: "/" },
  { label: title, href: Astro.url.pathname },
];
---

<BaseLayout title={title} description={description}>
  <div class="max-w-6xl mx-auto">
    <Breadcrumbs segments={crumbs ?? defaultCrumbs} />

    <h1 class="text-3xl font-bold mt-4 mb-2">{title}</h1>
    <p class="text-atlas-text-muted mb-8">{description}</p>

    <div class="mb-6">
      <input
        type="search"
        placeholder={`Search ${items.length} items...`}
        class="w-full max-w-md px-4 py-2 rounded-lg bg-atlas-surface border border-atlas-border text-atlas-text placeholder:text-atlas-text-muted focus:outline-none focus:border-atlas-accent transition-colors"
        data-catalog-search
      />
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3" data-catalog-grid>
      {items.map((item) => (
        <a
          href={item.href}
          class="group block p-4 rounded-lg bg-atlas-surface border border-atlas-border hover:border-atlas-accent/50 transition-colors"
          data-tags={item.tags.join(",")}
          data-title={item.title.toLowerCase()}
        >
          <h2 class="font-semibold text-atlas-text group-hover:text-atlas-accent transition-colors mb-1 line-clamp-2">{item.title}</h2>
          <p class="text-sm text-atlas-text-muted line-clamp-2">{item.description}</p>
          {item.tags.length > 0 && (
            <div class="flex flex-wrap gap-1 mt-2">
              {item.tags.slice(0, 3).map((tag) => (
                <span class="text-xs px-1.5 py-0.5 rounded bg-atlas-surface-2 text-atlas-text-muted">{tag}</span>
              ))}
            </div>
          )}
        </a>
      ))}
    </div>

    <slot />
  </div>
</BaseLayout>

<script>
  const input = document.querySelector<HTMLInputElement>("[data-catalog-search]");
  const grid = document.querySelector<HTMLElement>("[data-catalog-grid]");
  if (input && grid) {
    const cards = Array.from(grid.children) as HTMLElement[];
    input.addEventListener("input", () => {
      const q = input.value.toLowerCase();
      for (const card of cards) {
        const title = card.dataset.title ?? "";
        const tags = card.dataset.tags ?? "";
        const visible = !q || title.includes(q) || tags.includes(q);
        card.style.display = visible ? "" : "none";
      }
    });
  }
</script>
