---
import BaseLayout from "./BaseLayout.astro";
import Breadcrumbs from "../components/seo/Breadcrumbs.astro";

interface CatalogItem {
  slug: string;
  href: string;
  title: string;
  description: string;
  tags: Array<string | { label: string; href: string }>;
}

interface Props {
  title: string;
  description: string;
  items: CatalogItem[];
  breadcrumbs?: Array<{ label: string; href: string }>;
}

const { title, description, items, breadcrumbs: crumbs } = Astro.props;
const defaultCrumbs = [
  { label: "Atlas", href: "/" },
  { label: title, href: Astro.url.pathname },
];
---

<BaseLayout title={title} description={description}>
  <div class="max-w-6xl mx-auto">
    <Breadcrumbs segments={crumbs ?? defaultCrumbs} />

    <h1 class="text-3xl font-bold mt-4 mb-2">{title}</h1>
    <p class="text-atlas-text-muted mb-8">{description}</p>

    <div class="flex items-center gap-4 mb-6">
      <input
        type="search"
        placeholder={`Search ${items.length} items...`}
        class="flex-1 max-w-md px-4 py-2 rounded-lg bg-atlas-surface border border-atlas-border text-atlas-text placeholder:text-atlas-text-muted focus:outline-none focus:border-atlas-accent transition-colors"
        data-catalog-search
      />
      <span class="text-sm text-atlas-text-muted" data-catalog-count>
        {items.length} results
      </span>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3" data-catalog-grid>
      {items.map((item) => (
        <a
          href={item.href}
          class="group block p-4 rounded-lg bg-atlas-surface border border-atlas-border card-hover hover:border-atlas-accent/50"
          data-tags={item.tags.map((t) => typeof t === "string" ? t : t.label).join(",")}
          data-title={item.title.toLowerCase()}
        >
          <h2 class="font-semibold text-atlas-text group-hover:text-atlas-accent transition-colors mb-1 line-clamp-2">{item.title}</h2>
          <p class="text-sm text-atlas-text-muted line-clamp-2 mb-3">{item.description}</p>
          {item.tags.length > 0 && (
            <div class="flex flex-wrap gap-1.5">
              {item.tags.slice(0, 3).map((tag) => {
                if (typeof tag === "string") {
                  return <span class="tag-link">{tag.replace(/_/g, " ")}</span>;
                }
                return (
                  <span
                    class="tag-link tag-accent"
                    data-tag-href={tag.href}
                    onclick={`event.preventDefault(); event.stopPropagation(); window.location.href='${tag.href}'`}
                  >
                    {tag.label.replace(/_/g, " ")}
                  </span>
                );
              })}
            </div>
          )}
        </a>
      ))}
    </div>

    <p class="text-center text-atlas-text-muted text-sm mt-8 hidden" data-catalog-empty>
      No results match your search.
    </p>

    <slot />
  </div>
</BaseLayout>

<script>
  const input = document.querySelector<HTMLInputElement>("[data-catalog-search]");
  const grid = document.querySelector<HTMLElement>("[data-catalog-grid]");
  const countEl = document.querySelector<HTMLElement>("[data-catalog-count]");
  const emptyEl = document.querySelector<HTMLElement>("[data-catalog-empty]");
  if (input && grid) {
    const cards = Array.from(grid.children) as HTMLElement[];
    const total = cards.length;
    input.addEventListener("input", () => {
      const q = input.value.toLowerCase();
      let visible = 0;
      for (const card of cards) {
        const title = card.dataset.title ?? "";
        const tags = card.dataset.tags ?? "";
        const show = !q || title.includes(q) || tags.includes(q);
        card.style.display = show ? "" : "none";
        if (show) visible++;
      }
      if (countEl) {
        countEl.textContent = q ? `${visible} of ${total} results` : `${total} results`;
      }
      if (emptyEl) {
        emptyEl.classList.toggle("hidden", visible > 0);
      }
    });
  }
</script>
