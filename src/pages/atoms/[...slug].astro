---
import AtomLayout from "../../layouts/AtomLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const atoms = await getCollection("atoms");
  // Group by concept_type for related atoms
  const byType = new Map<string, typeof atoms>();
  for (const a of atoms) {
    const list = byType.get(a.data.concept_type) ?? [];
    list.push(a);
    byType.set(a.data.concept_type, list);
  }

  return atoms.map((atom) => {
    const siblings = (byType.get(atom.data.concept_type) ?? [])
      .filter((a) => a.id !== atom.id)
      .slice(0, 4);
    return {
      params: { slug: atom.id },
      props: { atom, relatedAtoms: siblings },
    };
  });
}

const { atom, relatedAtoms } = Astro.props;
const { Content } = await render(atom);
const contentPath = `atoms/${atom.id}.mdx`;
---

<AtomLayout atom={atom} contentPath={contentPath} relatedAtoms={relatedAtoms}>
  <Content />
</AtomLayout>
