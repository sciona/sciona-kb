---
import CatalogLayout from "../../layouts/CatalogLayout.astro";
import { getCollection } from "astro:content";

const cdgs = await getCollection("cdgs");

const items = cdgs.map((c) => ({
  slug: c.id,
  href: `/cdgs/${c.id}`,
  title: c.data.name,
  description: c.data.dejargonized_summary || c.data.summary,
  tags: [
    { label: c.data.paradigm, href: `/paradigm/${c.data.paradigm}` },
    { label: c.data.family, href: `/family/${c.data.family}` },
    ...c.data.variant_hints.slice(0, 2),
  ],
}));
---

<CatalogLayout
  title="Conceptual Directed Graphs"
  description={`${items.length} algorithmic pipelines decomposed into composable stages with explicit data flow.`}
  items={items}
/>
