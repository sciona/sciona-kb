---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/seo/Breadcrumbs.astro";
import AtomCompactCard from "../../components/content/AtomCompactCard.astro";
import { getCollection } from "astro:content";
import { getConceptDescription } from "../../data/concept-descriptions";

export async function getStaticPaths() {
  const atoms = await getCollection("atoms");
  const cdgs = await getCollection("cdgs");

  const atomTypes = new Set(atoms.map((a) => a.data.concept_type));
  const stageTypes = new Set(cdgs.flatMap((c) => c.data.stages.map((s) => s.concept_type)));
  const allTypes = [...new Set([...atomTypes, ...stageTypes])];

  const atomByFqdn = new Map(atoms.map((a) => [a.data.fqdn, a]));

  function fqdnToHref(fqdn: string): string {
    const parts = fqdn.replace("sciona.atoms.", "").split(".");
    return `/atoms/${parts.map((p) => p.replace(/_/g, "-")).join("/")}`;
  }
  function fqdnToTitle(fqdn: string): string {
    const name = fqdn.split(".").pop() ?? fqdn;
    return name.replace(/([a-z])([A-Z])/g, "$1 $2").replace(/^./, (c) => c.toUpperCase());
  }

  return allTypes.map((concept_type) => {
    const seen = new Set<string>();

    // Real collection atoms for this concept type
    const realAtoms = atoms.filter((a) => a.data.concept_type === concept_type);
    for (const a of realAtoms) seen.add(a.data.fqdn);

    // Synthesized atoms from CDG bindings
    const synthesized: Array<{ slug: string; href: string; title: string; description: string; domain: string }> = [];
    for (const cdg of cdgs) {
      for (const stage of cdg.data.stages) {
        if (stage.concept_type !== concept_type) continue;
        const binding = cdg.data.bindings.find((b) => b.stage_id === stage.stage_id);
        if (!binding?.bound_atom_fqdn || binding.status !== "active") continue;
        const fqdn = binding.bound_atom_fqdn;
        if (seen.has(fqdn)) continue;
        seen.add(fqdn);

        const existing = atomByFqdn.get(fqdn);
        if (existing) {
          realAtoms.push(existing);
        } else {
          synthesized.push({
            slug: fqdn,
            href: fqdnToHref(fqdn),
            title: fqdnToTitle(fqdn),
            description: stage.dejargonized_description || stage.description,
            domain: cdg.data.family,
          });
        }
      }
    }

    return { params: { concept_type }, props: { concept_type, realAtoms, synthesized } };
  });
}

const { concept_type, realAtoms, synthesized } = Astro.props;
const desc = getConceptDescription(concept_type);
const totalCount = realAtoms.length + synthesized.length;
const breadcrumbs = [
  { label: "Atlas", href: "/" },
  { label: "Concepts", href: "/concepts" },
  { label: desc.title, href: `/concept/${concept_type}` },
];
---

<BaseLayout title={`${desc.title} -- Concept Guide`} description={desc.oneLiner}>
  <div class="max-w-5xl mx-auto">
    <Breadcrumbs segments={breadcrumbs} />

    <!-- Hero -->
    <div class="mt-4 mb-8">
      <h1 class="text-3xl font-bold mb-1">
        <span class="mr-2">{desc.emoji}</span>{desc.title}
      </h1>
      <p class="text-lg text-atlas-accent">{desc.oneLiner}</p>
    </div>

    <!-- Explanation -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold mb-3">What is it?</h2>
      <p class="text-atlas-text-muted leading-relaxed">{desc.explanation}</p>
    </section>

    <!-- Analogy -->
    {desc.realWorldAnalogy && (
      <section class="mb-8 bg-atlas-surface rounded-lg border border-atlas-border p-5">
        <h2 class="text-sm font-semibold text-atlas-accent mb-2">Real-world analogy</h2>
        <p class="text-atlas-text-muted leading-relaxed">{desc.realWorldAnalogy}</p>
      </section>
    )}

    <!-- Why it matters -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold mb-3">Why does it matter?</h2>
      <p class="text-atlas-text-muted leading-relaxed">{desc.whyItMatters}</p>
    </section>

    <!-- Example uses -->
    {desc.exampleUses.length > 0 && (
      <section class="mb-10">
        <h2 class="text-xl font-semibold mb-3">Examples in practice</h2>
        <ul class="space-y-2">
          {desc.exampleUses.map((ex) => (
            <li class="flex gap-2 text-atlas-text-muted">
              <span class="text-atlas-accent shrink-0">-</span>
              <span>{ex}</span>
            </li>
          ))}
        </ul>
      </section>
    )}

    <hr class="section-rule mb-10" />

    <!-- Atom catalog -->
    <section>
      <h2 class="text-xl font-semibold mb-2">
        {desc.title} Atoms <span class="text-atlas-text-muted font-normal">({totalCount})</span>
      </h2>
      <p class="text-sm text-atlas-text-muted mb-5">
        All atoms in the Sciona catalog classified as {desc.title.toLowerCase()}.
      </p>

      {totalCount > 6 && (
        <div class="mb-5">
          <input
            type="search"
            placeholder={`Search ${totalCount} atoms...`}
            class="w-full max-w-md px-4 py-2 rounded-lg bg-atlas-surface border border-atlas-border text-atlas-text placeholder:text-atlas-text-muted focus:outline-none focus:border-atlas-accent transition-colors"
            data-catalog-search
          />
        </div>
      )}

      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3" data-catalog-grid>
        {realAtoms.map((a) => (
          <div data-title={a.data.title.toLowerCase() + " " + a.data.predicate_id.toLowerCase()} data-tags={a.data.domain}>
            <AtomCompactCard
              name={a.data.predicate_id}
              href={`/atoms/${a.id}`}
              description={a.data.informal_desc}
              domain={a.data.domain}
              conceptType={a.data.concept_type}
              inputCount={a.data.inputs.length}
              outputCount={a.data.outputs.length}
            />
          </div>
        ))}
        {synthesized.map((s) => (
          <div data-title={s.title.toLowerCase()} data-tags={s.domain}>
            <a
              href={s.href}
              class="group block rounded-lg bg-atlas-surface border border-atlas-border card-hover hover:border-atlas-accent/50 overflow-hidden"
            >
              <div class="h-[2px] bg-atlas-border"></div>
              <div class="px-3.5 py-3">
                <p class="font-mono text-xs font-semibold text-atlas-text-muted group-hover:text-atlas-accent transition-colors mb-1.5 line-clamp-1">{s.title}</p>
                <div class="flex flex-wrap gap-1 mb-2">
                  <span class="tag-link text-[9px]">via CDG</span>
                </div>
                <p class="text-[11px] text-atlas-text-muted leading-snug line-clamp-2">{s.description}</p>
              </div>
            </a>
          </div>
        ))}
      </div>

      <p class="text-center text-atlas-text-muted text-sm mt-8 hidden" data-catalog-empty>
        No atoms match your search.
      </p>
    </section>
  </div>
</BaseLayout>

<script>
  const input = document.querySelector<HTMLInputElement>("[data-catalog-search]");
  const grid = document.querySelector<HTMLElement>("[data-catalog-grid]");
  const emptyEl = document.querySelector<HTMLElement>("[data-catalog-empty]");
  if (input && grid) {
    const cards = Array.from(grid.children) as HTMLElement[];
    input.addEventListener("input", () => {
      const q = input.value.toLowerCase();
      let visible = 0;
      for (const card of cards) {
        const title = card.dataset.title ?? "";
        const tags = card.dataset.tags ?? "";
        const show = !q || title.includes(q) || tags.includes(q);
        card.style.display = show ? "" : "none";
        if (show) visible++;
      }
      if (emptyEl) emptyEl.classList.toggle("hidden", visible > 0);
    });
  }
</script>
