---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Not Found" description="The page you're looking for doesn't exist.">
  <div class="max-w-lg mx-auto text-center py-24">
    <p class="text-6xl font-bold text-atlas-accent mb-4">404</p>
    <h1 class="text-2xl font-bold mb-2">Page Not Found</h1>
    <p class="text-atlas-text-muted mb-8">The atom you're looking for may have been decomposed.</p>
    <a href="/" class="px-6 py-3 rounded-lg bg-atlas-accent text-white font-medium hover:bg-atlas-accent-hover transition-colors">
      Back to Atlas
    </a>
  </div>
</BaseLayout>
