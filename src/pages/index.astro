---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import PlatformCTA from "../components/cta/PlatformCTA.astro";

const cdgs = await getCollection("cdgs");
const atoms = await getCollection("atoms");
const solutions = await getCollection("solutions");

// Featured: CDGs with most bound atoms
const featured = [...cdgs]
  .sort((a, b) => (b.data.binding_summary?.bound_active ?? 0) - (a.data.binding_summary?.bound_active ?? 0))
  .slice(0, 6);

// Unique paradigms and families for navigation
const paradigms = [...new Set(cdgs.map((c) => c.data.paradigm))].sort();
const families = [...new Set(cdgs.map((c) => c.data.family))].sort();
---

<BaseLayout title="Algorithm Atlas" description="Wikipedia-style encyclopedia of algorithms, mental models, and competitive solutions -- powered by Sciona's composable atom system.">
  <div class="max-w-6xl mx-auto">
    <!-- Hero -->
    <section class="text-center py-16">
      <h1 class="text-5xl font-bold mb-4">
        <span class="text-atlas-accent">Algorithm</span> Atlas
      </h1>
      <p class="text-xl text-atlas-text-muted max-w-2xl mx-auto mb-8">
        Explore {cdgs.length} algorithmic pipelines, {atoms.length} mathematical atoms, and {solutions.length} competition-winning solutions -- all interconnected and composable.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/cdgs" class="px-6 py-3 rounded-lg bg-atlas-accent text-white font-medium hover:bg-atlas-accent-hover transition-colors">
          Browse CDGs
        </a>
        <a href="/atoms" class="px-6 py-3 rounded-lg border border-atlas-border text-atlas-text font-medium hover:border-atlas-accent hover:text-atlas-accent transition-colors">
          Explore Atoms
        </a>
        <a href="/solutions" class="px-6 py-3 rounded-lg border border-atlas-border text-atlas-text font-medium hover:border-atlas-accent hover:text-atlas-accent transition-colors">
          Solutions
        </a>
      </div>
    </section>

    <!-- Stats -->
    <section class="grid grid-cols-3 gap-4 mb-16">
      <div class="bg-atlas-surface rounded-lg border border-atlas-border p-6 text-center">
        <p class="text-3xl font-bold text-atlas-accent">{atoms.length}</p>
        <p class="text-atlas-text-muted text-sm">Atoms</p>
      </div>
      <div class="bg-atlas-surface rounded-lg border border-atlas-border p-6 text-center">
        <p class="text-3xl font-bold text-atlas-accent">{cdgs.length}</p>
        <p class="text-atlas-text-muted text-sm">CDGs</p>
      </div>
      <div class="bg-atlas-surface rounded-lg border border-atlas-border p-6 text-center">
        <p class="text-3xl font-bold text-atlas-accent">{solutions.length}</p>
        <p class="text-atlas-text-muted text-sm">Solutions</p>
      </div>
    </section>

    <!-- Featured CDGs -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-6">Featured Pipelines</h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {featured.map((cdg) => (
          <a href={`/cdgs/${cdg.id}`} class="group block p-4 rounded-lg bg-atlas-surface border border-atlas-border hover:border-atlas-accent/50 transition-colors">
            <h3 class="font-semibold group-hover:text-atlas-accent transition-colors mb-1 line-clamp-2">{cdg.data.name}</h3>
            <p class="text-sm text-atlas-text-muted line-clamp-2 mb-2">{cdg.data.dejargonized_summary}</p>
            <div class="flex gap-2">
              <span class="text-xs px-1.5 py-0.5 rounded bg-atlas-accent/10 text-atlas-accent">{cdg.data.paradigm}</span>
              <span class="text-xs px-1.5 py-0.5 rounded bg-atlas-surface-2 text-atlas-text-muted">{cdg.data.family}</span>
              {cdg.data.binding_summary && (
                <span class="text-xs px-1.5 py-0.5 rounded bg-atlas-surface-2 text-atlas-text-muted">
                  {cdg.data.binding_summary.bound_active}/{cdg.data.binding_summary.total_stages} bound
                </span>
              )}
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Paradigms -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-4">By Paradigm</h2>
      <div class="flex flex-wrap gap-2">
        {paradigms.map((p) => (
          <a href={`/paradigm/${p}`} class="px-3 py-1.5 rounded-lg bg-atlas-surface border border-atlas-border text-sm text-atlas-text-muted hover:text-atlas-accent hover:border-atlas-accent/50 transition-colors">{p}</a>
        ))}
      </div>
    </section>

    <!-- Families -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-4">By Problem Family</h2>
      <div class="flex flex-wrap gap-2">
        {families.map((f) => (
          <a href={`/family/${f}`} class="px-3 py-1.5 rounded-lg bg-atlas-surface border border-atlas-border text-sm text-atlas-text-muted hover:text-atlas-accent hover:border-atlas-accent/50 transition-colors">{f}</a>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="text-center py-12 bg-atlas-surface rounded-lg border border-atlas-border">
      <h2 class="text-2xl font-bold mb-2">Build with Sciona</h2>
      <p class="text-atlas-text-muted mb-6">Compose atoms into custom algorithmic pipelines. No boilerplate.</p>
      <PlatformCTA label="Get Started with Sciona" />
    </section>
  </div>
</BaseLayout>
